###############################################################################
### REQUIRED ENVIRONMENT VARIABLES - SENSITIVE INFORMATION                  ###
### DO NOT STORE RAW SECRETS HERE IN PLAINTEXT IF AVOIDABLE                 ###
### DO NOT UPLOAD OR SHARE THIS FILE UNDER ANY CIRCUMSTANCES                ###
###############################################################################

# Ethereum private key (Required for deploying contracts)
# Note: Do not wrap the key in quotes. It should start with or without 0x.
CRE_ETH_PRIVATE_KEY=0xYourPrivateKeyHere

# Sepolia RPC URL (replace YOUR_INFURA_PROJECT_ID with your real ID)
# Example for Infura:
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Default target used when --target flag is not specified
CRE_TARGET=staging-settings
